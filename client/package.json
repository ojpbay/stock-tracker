{
  "name": "client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest --config jest.config.js",
    "test:ci": "jest --config jest.config.js --ci --coverage"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
